# ==============================================================================
# FACULTY APPRAISAL SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' and fill in the actual values.
# NEVER commit the actual '.env' file to source control.

# --- 1. Database Configuration ---
# Format: postgresql+asyncpg://user:password@host:port/database
# For Supabase/PgBouncer: use port 6543 and the pooled connection string.
DATABASE_URL="postgresql+asyncpg://postgres.[ID]:[PWD]@aws-0-asia-south-1.pooler.supabase.com:6543/postgres"

# --- 2. Security & Authentication ---
# USE_LOCAL_AUTH: Set to 'true' to use the built-in PostgreSQL auth. 
# Set to 'false' to use Supabase Auth.
USE_LOCAL_AUTH="true"

# JWT_SECRET_KEY: A long random string to sign tokens. 
# Generate one using: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY="your-super-secret-random-string"

# ALLOW_MOCK_USER: (Development ONLY) Set to 'true' to bypass login.
ALLOW_MOCK_USER="false"

# --- 3. System URLs ---
# APP_URL: The public URL of this BACKEND service. Used for email verification links.
# Example: https://your-backend.a.run.app
APP_URL="http://localhost:8000"

# FRONTEND_URL: The public URL of your Netlify/React frontend. Used for redirects.
# Example: https://your-app.netlify.app
FRONTEND_URL="http://localhost:5173"

# --- 4. Email (SMTP) Configuration ---
# Required for sending verification emails.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password-not-regular-password"
MAIL_FROM="your-email@gmail.com"

# --- 5. File Storage Configuration ---
# OPTION A: Local Storage (Internal Server)
USE_LOCAL_STORAGE="false"
LOCAL_STORAGE_DIR="./uploads"

# OPTION B: Google Cloud Storage (Production)
GCP_STORAGE_BUCKET="your-gcs-bucket-name"
GCP_PROJECT_ID="your-gcp-project-id"

# --- 6. Supabase (Optional/Legacy) ---
# Only required if USE_LOCAL_AUTH="false"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
