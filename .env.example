# --- Database Configuration ---
# Example for local development: postgresql+asyncpg://app_user:change_me@localhost:5432/faculty_appraisal
# Example for GCP Cloud SQL: postgresql+asyncpg://app_user:PASSWORD@<INSTANCE_IP>:5432/faculty_appraisal
DATABASE_URL="postgresql+asyncpg://user:password@host:port/database_name"

# --- Security & Authentication ---
# Generate a long random string for production
JWT_SECRET_KEY="your-secret-key-for-local-jwt"
USE_LOCAL_AUTH="true"

# Set to 'true' to allow login without a valid token (Development ONLY)
ALLOW_MOCK_USER="false"

# --- Google Cloud Storage (File Uploads) ---
# The bucket name where PDFs/Images will be stored
GCP_STORAGE_BUCKET="your-gcs-bucket-name"
# Your Google Cloud Project ID
GCP_PROJECT_ID="your-gcp-project-id"

# --- System URLs ---
# The public URL of your backend (optional, for logging/links)
APP_URL="http://localhost:8000"
