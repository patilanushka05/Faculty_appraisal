# Database
# For Supabase, use the connection string provided in the Supabase dashboard.
# For local, use: postgresql://user:password@localhost:5432/dbname
DATABASE_URL="postgresql://user:password@host:port/database_name"

# Supabase Configuration (Fallback)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Local Authentication Toggle
# Set to 'true' to use local Python-based JWT auth instead of Supabase Auth.
USE_LOCAL_AUTH="false"
JWT_SECRET_KEY="generate-a-long-random-secret-key-for-local-jwt"
ALLOW_MOCK_USER="false"

# Email SMTP Settings (For Verification Link)
# If using Gmail, use an "App Password" not your primary password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-system-email@gmail.com"
SMTP_PASSWORD="your-app-specific-password"
MAIL_FROM="your-system-email@gmail.com"

# The public URL of your backend (required for verification links)
APP_URL="http://localhost:8000"

# Local Storage Toggle
# Set to 'true' to save files to the local file system instead of Supabase Storage.
USE_LOCAL_STORAGE="false"
LOCAL_STORAGE_DIR="./uploads"
